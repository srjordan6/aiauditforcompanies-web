---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Coming soon — aiauditforcompanies.com"
  description="The AI audit that surfaces what unmanaged AI is silently costing your business. Launching soon. From SRJ Consulting & Services LLC."
  ogTitle="Find your $670K. Coming soon."
  ogDescription="The AI audit that surfaces what unmanaged AI is silently costing your business."
  noindex={true}
>
  <div class="content-srj min-h-screen flex flex-col px-6 py-8">
    <div class="text-sm font-medium tracking-wide" style="color: var(--color-navy);">
      aiauditforcompanies.com
    </div>

    <section class="flex-1 flex flex-col items-start justify-center py-16 max-w-[880px]">
      <h1 class="font-bold leading-[1.05] tracking-tight" style="font-family: var(--font-display); color: var(--color-navy); font-size: clamp(2.75rem, 7vw, 5rem);">
        Find your $670K.
        <span class="block font-medium mt-4" style="color: var(--color-orange); font-size: 0.55em;">
          Coming soon.
        </span>
      </h1>

      <hr class="w-16 h-[3px] border-0 my-8" style="background: var(--color-orange);" />

      <p class="max-w-[640px]" style="color: var(--color-gray-srj); font-size: clamp(1.0625rem, 1.6vw, 1.25rem);">
        The AI audit that surfaces what unmanaged AI is silently costing your business.
      </p>
    </section>

    <footer class="text-sm pt-8 leading-relaxed" style="color: var(--color-gray-srj); border-top: 1px solid var(--color-rule-light);">
      A property of SRJ Consulting &amp; Services LLC.<br />
      Visit the advisory at <a href="https://srjconsultingservices.com" rel="noopener" class="font-medium border-b border-transparent transition-colors hover:opacity-80" style="color: var(--color-orange);">srjconsultingservices.com</a>.
    </footer>
  </div>
</Layout>